VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=HTTP://LOCALHOST:5055
VITE_NEXT_BASE=http://localhost:3002

# Production: deepquill /api/points/award accepts x-admin-key matching ADMIN_KEY OR x-internal-proxy matching
# INTERNAL_PROXY_SECRET (same secret in agnes-next + deepquill). Set at least one pair.
# ADMIN_KEY=
# INTERNAL_PROXY_SECRET=

# Vercel Cron: GET /api/cron/daily-contest-summary (see agnes-next/vercel.json). Must match Authorization header.
# CRON_SECRET=
# DEEPQUILL_URL=https://your-deepquill-host  (server-side; cron route calls this for the job)

# Production: training/instruction MP4s (single source of truth). Base only — no per-file URLs in code.
# Trailing slash optional; filenames are listed in src/lib/trainingVideoUrl.ts (TRAINING_VIDEO_FILES).
# Example: https://xxxx.public.blob.vercel-storage.com/training  (objects: fb-instructions-iPhone.mp4, …)
# NEXT_PUBLIC_TRAINING_VIDEO_BASE_URL=https://xxxx.public.blob.vercel-storage.com/training
# Redeploy after changing NEXT_PUBLIC_* (inlined at build time for client components).

# Server-only: log share claim proxy / deepquill auth (Vercel function logs). Remove after debugging.
# SHARE_FLOW_DEBUG=1

# Client: log FB claim response in browser console
# NEXT_PUBLIC_SHARE_FLOW_DEBUG=1

# Entry funnel split (Lightning-first). Defaults in code are 20/40/40 if unset. NEXT_PUBLIC_* is build-time.
# seen_terminal / seen_protocol / seen_contest cookies (1-year) track Phase 2; entry_variant (7-day) is Phase 3 sticky.
NEXT_PUBLIC_ENTRY_SPLIT_TERMINAL=20
NEXT_PUBLIC_ENTRY_SPLIT_PROTOCOL=40
NEXT_PUBLIC_ENTRY_SPLIT_CONTEST=40

# Temporary: set to 1 to log funnel routing to server + browser (remove after debugging)
# NEXT_PUBLIC_ENTRY_FUNNEL_DEBUG=1

# Terminal: mobile focus / keyboard assist debug (browser console + small overlay)
# NEXT_PUBLIC_TERMINAL_MOBILE_DEBUG=1

# Share video API routes redirect to static /videos/* on this origin (required on Vercel; avoids bundling public/videos into serverless).
# NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app
# Optional override if videos are hosted elsewhere:
# SHARE_VIDEO_PUBLIC_BASE_URL=https://cdn.example.com
# NEXT_PUBLIC_SHARE_VIDEO_BASE_URL=https://cdn.example.com

# Signal Room access (default: public, no gate)
# SIGNAL_ROOM_ACCESS_MODE=public|code|eligibility|hybrid
# SIGNAL_ROOM_ACCESS_CODE=...  (required when mode is code or hybrid)
# SIGNAL_ROOM_CODE_TTL_MINUTES=...  (optional; code grants expire after this many minutes)
# SIGNAL_ROOM_ACCESS_EMAILS=email@example.com,other@example.com  (for eligibility/hybrid)

# Signal Room: direct video upload (Vercel Blob, client-side upload). Required in production for composer uploads.
# Create store in Vercel dashboard → Storage → Blob; link to agnes-next project.
# BLOB_READ_WRITE_TOKEN=
