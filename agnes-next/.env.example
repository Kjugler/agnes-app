VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=HTTP://LOCALHOST:5055
VITE_NEXT_BASE=http://localhost:3002

# Required in production for points/award proxy to deepquill. Set same value in both agnes-next and deepquill.
# ADMIN_KEY=

# Entry funnel split (Spec 1 - Lightning-first). Must sum to 100.
# Used when no ?v= override and no variant cookie. Client-side: NEXT_PUBLIC_ prefix required.
NEXT_PUBLIC_ENTRY_SPLIT_TERMINAL=25
NEXT_PUBLIC_ENTRY_SPLIT_PROTOCOL=35
NEXT_PUBLIC_ENTRY_SPLIT_CONTEST=40

# Share video API routes redirect to static /videos/* on this origin (required on Vercel; avoids bundling public/videos into serverless).
# NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app
# Optional override if videos are hosted elsewhere:
# SHARE_VIDEO_PUBLIC_BASE_URL=https://cdn.example.com
# NEXT_PUBLIC_SHARE_VIDEO_BASE_URL=https://cdn.example.com

# Signal Room access (default: public, no gate)
# SIGNAL_ROOM_ACCESS_MODE=public|code|eligibility|hybrid
# SIGNAL_ROOM_ACCESS_CODE=...  (required when mode is code or hybrid)
# SIGNAL_ROOM_CODE_TTL_MINUTES=...  (optional; code grants expire after this many minutes)
# SIGNAL_ROOM_ACCESS_EMAILS=email@example.com,other@example.com  (for eligibility/hybrid)
