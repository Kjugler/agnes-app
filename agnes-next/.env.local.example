# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Database (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Site URL for social sharing (required in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Deepquill API (required in production)
# NEXT_PUBLIC_API_BASE_URL=https://your-deepquill-url.railway.app
# DEEPQUILL_URL=https://your-deepquill-url.railway.app

# Stress Test Mode (canonical flags)
# STRESS_TEST_MODE=1           Master server-side flag. Enables email subject prefix [PUBLIC BETA TEST]
#                             and short body note on all transactional emails (agnes-next + deepquill).
# NEXT_PUBLIC_STRESS_TEST_MODE=1  Client/UI flag. Enables banners, share caption footer, etc.
# Set both for public beta. No separate EMAIL_CONTEST_BANNER needed.
# STRESS_TEST_MODE=1
# NEXT_PUBLIC_STRESS_TEST_MODE=1

# Transactional Email (Spec 2)
# When 1: send reminder emails, commission emails, referral emails. When unset: no transactional emails sent.
# TRANSACTIONAL_EMAIL_ENABLED=1

# EMAIL_CONTEST_BANNER=1       Legacy override; still supported. Prefer STRESS_TEST_MODE.

# Entry funnel split (Spec 1 - Lightning-first). Must sum to 100.
NEXT_PUBLIC_ENTRY_SPLIT_TERMINAL=25
NEXT_PUBLIC_ENTRY_SPLIT_PROTOCOL=35
NEXT_PUBLIC_ENTRY_SPLIT_CONTEST=40

# Note: Copy this to .env.local and add your actual keys
