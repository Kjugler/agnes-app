VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=HTTP://LOCALHOST:5055
VITE_NEXT_BASE=http://localhost:3002

# Stress test: when 1, all emails get [PUBLIC BETA TEST] subject prefix + short body note
# STRESS_TEST_MODE=1

STRIPE_SECRET_KEY="sk_test_your_secret_key_here"
STRIPE_PRICE_ID="price_your_price_id_here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"
SUBSCRIBE_FAIL_OPEN=true   # default if unset
# Required in production for points/award. Set same value in both agnes-next and deepquill.
# ADMIN_KEY=
SUBSCRIBE_DEV_OVERRIDE=true

# Fulfillment: when Order lives in agnes-next DB, set this to that DB path.
# Example (Windows): FULFILLMENT_DATABASE_URL=file:C:/dev/agnes-app/agnes-next/dev-next.db
# FULFILLMENT_DATABASE_URL=

# Fulfillment API auth: token workers enter at /admin/fulfillment/auth. x-admin-key also accepted.
# FULFILLMENT_ACCESS_TOKEN=

# Optional: reservation TTL in minutes (default 30)
# FULFILLMENT_RESERVATION_TTL_MINUTES=30

# Optional: BCC order alerts to this email when marking orders shipped
# ORDER_ALERT_EMAIL=

# Production: Railway/Render set PORT; local dev uses 5055
# PORT=5055

# Signal Room / Reviews: when true (and NODE_ENV=development), new signals/reviews auto-approve.
# Recommended for local dev so submitted content appears immediately.
# AUTO_APPROVE_USER_CONTENT=true

# Daily contest summary (ribbons + Signal Room): default claim copy when none stored on the row yet.
# DAILY_SUMMARY_CASH_CLAIM_DEFAULT=

# Schedule: at ~2:00 AM America/Denver call deepquill with x-admin-key:
#   GET or POST /api/admin/jobs/daily-contest-summary
# Example UTC hits (approximate): MST ~ 09:05 UTC, MDT ~ 08:05 UTC. Prefer TZ-aware cron or hourly "Denver hour===2" guard.
#
# Production deploy (deepquill): set DATABASE_URL to prod, then from repo deepquill/ run:
#   npx prisma migrate deploy
# Then deploy the app (deepquill + agnes-next). After first deploy, trigger the job once and check admin job status panel.
