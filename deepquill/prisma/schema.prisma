// prisma/schema.prisma
//
// ⚠️ CRITICAL: Run Prisma commands from deepquill ROOT directory.
// Correct: cd deepquill && npx prisma generate
// Correct: cd deepquill && npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                           String               @id @default(cuid())
  email                        String               @unique
  fname                        String?
  lname                        String?
  firstName                    String?
  code                         String               @unique
  referralCode                 String               @unique
  preferredDiscountCode        String? // User's preferred discount code (auto-applied to future checkouts)
  referredBy                   String?
  // Latest active referral tracking (for automatic attribution)
  lastReferredByUserId         String? // User ID of the most recent referrer
  lastReferralCode             String? // Referral code used in most recent referral
  lastReferralAt               DateTime? // When the most recent referral occurred
  lastReferralSource           String? // Source: "email" | "link" | "unknown"
  lastReferralEmail            String? // The referred email address (for debugging)
  createdAt                    DateTime             @default(now())
  points                       Int                  @default(0)
  earnedPurchaseBook           Boolean              @default(false)
  rabbit1Completed             Boolean              @default(false)
  rabbitStep                   Int                  @default(500)
  rabbitTarget                 Int?
  rabbitCatches                Int                  @default(0)
  lastRabbitBonusIntent        String?
  rabbitSeq                    Int                  @default(1)
  lastRabbitCatchAt            DateTime?
  phone                        String?
  handleX                      String?
  handleInstagram              String?
  handleTiktok                 String?
  handleTruth                  String?
  referralEarningsCents        Int                  @default(0)
  associateBalanceCents        Int                  @default(0)
  associateLifetimeEarnedCents Int                  @default(0)
  associateFriendsSavedCents   Int                  @default(0)
  noPurchaseEmailSentAt        DateTime?
  contestJoinedAt              DateTime?
  nonParticipantEmailSentAt    DateTime?
  missionaryEmailSentAt        DateTime?
  engagedEmailSentAt           DateTime?
  terminalDiscoveryAwarded    Boolean               @default(false)
  events                       Event[]
  badges                       UserBadge[]
  posts                        Post[]
  purchases                    Purchase[]
  ledger                       Ledger[]
  referralConversions          ReferralConversion[]
  signals                      Signal[]
  signalReplies                SignalReply[]
  signalAcknowledges           SignalAcknowledge[]
  signalComments               SignalComment[]
  signalCommentUpvotes         SignalCommentUpvote[]
  reviews                      Review[]
  customers                    Customer[] // Customers linked to this User
  dailyContestSummariesFirst   DailyContestSummary[] @relation("DailyFirst")
  dailyContestSummariesSecond  DailyContestSummary[] @relation("DailySecond")
  dailyContestSummariesThird   DailyContestSummary[] @relation("DailyThird")
  dailyContestSummariesLiveLeader DailyContestSummary[] @relation("DailyLiveLeader")
  dailyContestSummariesCashWinner DailyContestSummary[] @relation("DailyCashWinner")

  @@index([referralCode])
}

/// Canonical daily contest rollup for ribbons, Signal bulletin, and admin (America/Denver calendar date).
model DailyContestSummary {
  id           String @id @default(cuid())
  /// YYYY-MM-DD in America/Denver (the **day scored**, not the job run date)
  summaryDate  String @unique

  firstUserId    String?
  secondUserId   String?
  thirdUserId    String?
  firstUser      User?   @relation("DailyFirst", fields: [firstUserId], references: [id], onDelete: SetNull)
  secondUser     User?   @relation("DailySecond", fields: [secondUserId], references: [id], onDelete: SetNull)
  thirdUser      User?   @relation("DailyThird", fields: [thirdUserId], references: [id], onDelete: SetNull)

  firstDailyPoints    Int?
  secondDailyPoints   Int?
  thirdDailyPoints    Int?

  /// Derived at job time: First + last initial (e.g. "Jane D.")
  firstDisplayName   String?
  secondDisplayName  String?
  thirdDisplayName   String?

  /// Admin override for public display (takes precedence when set)
  firstDisplayOverride   String?
  secondDisplayOverride  String?
  thirdDisplayOverride   String?

  /// Users with net positive ledger points earned that summary day (see job; excludes placement awards for that day)
  contestantCount Int @default(0)

  liveLeaderUserId       String?
  liveLeader             User?   @relation("DailyLiveLeader", fields: [liveLeaderUserId], references: [id], onDelete: SetNull)
  liveLeaderDisplayName  String?
  liveLeaderTotalPoints  Int?

  cashChallengeWinnerUserId      String?
  cashChallengeWinner            User?   @relation("DailyCashWinner", fields: [cashChallengeWinnerUserId], references: [id], onDelete: SetNull)
  cashChallengeWinnerDisplayName String?
  cashChallengeClaimInstructions String?
  cashChallengeClaimed           Boolean @default(false)

  placementPointsAwardedAt DateTime?

  generatedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manuallyEditedNames Boolean @default(false)

  @@index([summaryDate])
}

/// Singleton row (id = daily_contest_summary): telemetry for the daily summary job (cron + manual regenerate).
model DailyContestSummaryJobStatus {
  id            String    @id
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  updatedAt     DateTime  @updatedAt
}

model Ledger {
  id        String     @id @default(cuid())
  sessionId String? // Stripe checkout session id (for idempotency and audit)
  userId    String // Buyer principal (canonical User)
  type      LedgerType
  points    Int        @default(0) // Points delta (can be negative)
  usd       Decimal    @default(0) // USD cents delta (can be negative)
  amount    Int? // Generic amount (points or cents, depending on type)
  currency  String? // Currency code (e.g., 'usd', 'points')
  note      String? // Human-readable note
  meta      Json? // Structured metadata (product, reason, referrerUserId, etc.)
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])

  @@unique([sessionId, type, userId], name: "uniq_ledger_type_session_user") // Idempotency: one ledger entry per session+type+user
  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([type, createdAt])
}

enum LedgerType {
  // Purchase & Points
  PURCHASE_RECORDED // Purchase transaction recorded
  POINTS_AWARDED_PURCHASE // Points awarded for purchase (+500)
  POINTS_SKIPPED_PURCHASE // Points skipped (with reason in meta)

  // Legacy point types (keep for backward compatibility)
  PURCHASE_BOOK
  REFER_FRIEND_PAYOUT
  REFER_EMAIL
  REFER_PURCHASE
  ASSOCIATE_PAYOUT
  MANUAL_ADJUST
  SHARE_X
  SHARE_IG
  SHARE_FB
  TEXT_FRIEND_SHARED // Text-a-friend share from score page (+100 pts, daily cap)
  SHARE_TRUTH
  SHARE_TT
  CONTEST_JOIN
  CONTEST_EXPLICIT_ENTRY // Explicit contest entry via score page (+500 pts, idempotent)
  TERMINAL_DISCOVERY_BONUS // Hidden terminal path discovery (+250 pts, once per user)
  SUBSCRIBE_DIGEST
  TRIVIA
  RABBIT_BONUS
  SIGNUP_BONUS

  // Referral & Commission
  REFERRAL_DISCOUNT_APPLIED // Discount applied to buyer (negative amount)
  REFERRAL_COMMISSION_EARNED // Commission earned by referrer (positive amount, $2.00 per purchase)
  REFERRAL_POINTS_AWARDED // Points awarded to sponsor for referred purchase (+5000)
  FRIEND_SAVINGS_CREDITED // Friend savings credited to sponsor (discount amount applied)
  REFERRAL_SKIPPED // Referral skipped (with reason in meta)

  // Fulfillment Obligations
  FULFILLMENT_PAPERBACK_SHIP // Paperback shipment owed
  FULFILLMENT_EBOOK_GRANT // eBook download granted
  FULFILLMENT_AUDIO_PREORDER // Audio preorder fulfillment
  
  // Webhook Errors (Part G)
  WEBHOOK_MISSING_PRODUCT // Product metadata missing from Stripe session

  // Email Delivery Tracking
  EMAIL_PURCHASE_CONFIRMATION // Purchase confirmation email delivery outcome
  EMAIL_AP_SALE_NOTIFICATION // Associate Publisher sale notification email delivery outcome

  // Moderation approval bonuses
  SIGNAL_APPROVED // +100 pts when Signal approved
  REVIEW_APPROVED  // +150 pts when Review approved

  // Daily contest placement (previous calendar day in America/Denver — awarded by automated job)
  DAILY_CONTEST_FIRST // +10 placement points (1st)
  DAILY_CONTEST_SECOND // +5 (2nd)
  DAILY_CONTEST_THIRD // +3 (3rd)
}

model Event {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  type      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, type, createdAt])
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  points      Int
  actionType  String
  actionUrl   String?
  cooldownHrs Int?
  maxTimes    Int         @default(1)
  active      Boolean     @default(true)
  userBadges  UserBadge[] // ADD THIS LINE
}

model UserBadge {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  badgeId    String
  times      Int      @default(1)
  lastEarned DateTime @default(now())

  @@unique([userId, badgeId])
}

model Post {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  content   String
  status    String   @default("approved")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Purchase {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  sessionId String   @unique
  amount    Int?
  currency  String?
  source    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ReferralConversion {
  id              String    @id @default(cuid())
  referrerUserId  String
  referralCode    String // Required: the referral code used for this conversion
  buyerEmail       String?
  stripeSessionId String    @unique
  commissionCents Int       @default(0)
  savingsCents     Int       @default(0) // Money saved by buyer (discount amount)
  amountPaidCents  Int       @default(0) // Amount buyer actually paid (after discount)
  product          String?   // Part G: NO DEFAULT - must be explicitly set, nullable to detect missing
  currency         String?   // Optional, derived from Stripe
  createdAt        DateTime  @default(now())
  lastDigestDate   DateTime? // Date when this conversion was included in a digest
  referrer         User      @relation(fields: [referrerUserId], references: [id])

  @@index([referrerUserId, createdAt])
  @@index([referralCode])
  @@index([lastDigestDate])
}

model Customer {
  id              String   @id @default(cuid())
  email           String   @unique
  userId          String?  @unique // Link to canonical User principal (optional - may not have contest account)
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name            String?
  phone           String?
  shippingStreet  String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]

  @@index([email])
  @@index([userId])
}

model FulfillmentUser {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  active          Boolean  @default(true)
  printedOrders   Order[]  @relation("LabelPrinter")
  shippedOrders   Order[]  @relation("Shipper")
  reservedOrders  Order[]  @relation("Reserver")
  payments        FulfillmentPayment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([active])
}

model FulfillmentPayment {
  id                String         @id @default(cuid())
  fulfillmentUserId String
  fulfillmentUser   FulfillmentUser @relation(fields: [fulfillmentUserId], references: [id], onDelete: Restrict)
  amountCents       Int
  paidAt            DateTime       @default(now())
  note              String?
  createdAt         DateTime       @default(now())

  @@index([fulfillmentUserId])
}

model Order {
  id              String   @id @default(cuid())
  customer        Customer @relation(fields: [customerId], references: [id])
  customerId      String
  stripeSessionId String   @unique
  amountTotal     Int? // in cents
  currency        String?
  contestPlayerId String? // FK to User.id (optional)
  referralCode    String?
  pointsAwarded   Boolean  @default(false)

  // Commission tracking (optional, for admin visibility)
  commissionCents  Int?
  friendSavedCents Int?

  // Fulfillment fields
  status           String           @default("pending")
  reservedAt       DateTime?        // Claim when worker fetches; 30min TTL
  reservedById     String?
  reservedBy       FulfillmentUser? @relation("Reserver", fields: [reservedById], references: [id])
  labelPrintedAt   DateTime?
  shippedAt        DateTime?
  labelPrintedById String?
  shippedById      String?
  labelPrintedBy   FulfillmentUser? @relation("LabelPrinter", fields: [labelPrintedById], references: [id])
  shippedBy        FulfillmentUser?  @relation("Shipper", fields: [shippedById], references: [id])

  // Shipping information
  shippingName         String?
  shippingAddressLine1 String?
  shippingAddressLine2 String?
  shippingCity         String?
  shippingState        String?
  shippingPostalCode   String?
  shippingCountry      String?
  shippingPhone        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, createdAt])
  @@index([stripeSessionId])
  @@index([contestPlayerId])
  @@index([status])
  @@index([reservedById])
  @@index([status, reservedAt])
  @@index([labelPrintedById])
  @@index([shippedById])
}

enum SignalStatus {
  APPROVED
  HELD
  REJECTED
}

enum SignalHeldReason {
  PROFANITY
  HARASSMENT
  HATE
  CLAIM
  LINK
  OTHER
  MEDIA_UPLOAD
}

enum SignalType {
  ARCHIVE
  LOCATION
  VISUAL
  NARRATIVE
  PLAYER_QUESTION
  PODCASTER_PROMPT
  SPECULATIVE
}

enum SignalPublishStatus {
  DRAFT
  PUBLISHED
}

model Signal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Author
  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  author      String?
  isSystem    Boolean @default(false)
  isAnonymous Boolean @default(false)

  // Content
  text    String  // legacy; min 3 chars
  title   String?
  type    SignalType? @default(NARRATIVE)
  content String?

  // Media
  mediaType String?
  mediaUrl  String?

  // Location
  locationTag  String?
  locationName String?
  locationLat  Float?
  locationLng  Float?
  tags         Json?

  // Discussion & scheduling
  discussionEnabled Boolean @default(true)
  publishAt         DateTime?
  publishStatus     SignalPublishStatus? @default(PUBLISHED)

  // Moderation
  status     SignalStatus      @default(APPROVED)
  heldReason SignalHeldReason?
  heldAt     DateTime?
  approvedAt DateTime?
  rejectedAt DateTime?

  // Coarse geo at time of posting (no raw IP stored here)
  countryCode String? // e.g. "US"
  region      String? // e.g. "UT" (state/region code)

  // Relationships
  replies      SignalReply[]
  acknowledges SignalAcknowledge[]
  comments     SignalComment[]
  events       SignalEvent[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([publishStatus, createdAt])
  @@index([type, createdAt])
  @@index([countryCode, region, createdAt])
}

model SignalReply {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  signalId String
  signal   Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  isAnonymous Boolean @default(false)
  text        String // enforce 140 chars at app layer

  @@index([signalId, createdAt])
}

model SignalAcknowledge {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  signalId String
  signal   Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([signalId, userId])
  @@index([signalId, createdAt])
}

model SignalComment {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  signalId    String
  signal      Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  commentText String
  upvotes     Int      @default(0)
  isFlagged   Boolean  @default(false)
  flagReason  String?
  upvoteRecords SignalCommentUpvote[]

  @@index([signalId, createdAt])
}

model SignalCommentUpvote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  commentId String
  comment   SignalComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
}

model SignalEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  signalId  String
  signal    Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  eventText String

  @@index([signalId, createdAt])
}

enum ReviewStatus {
  APPROVED
  HELD
  REJECTED
}

enum ReviewHeldReason {
  PROFANITY
  HARASSMENT
  HATE
  CLAIM
  LINK
  OTHER
}

model Review {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Author
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  rating Int // 1-5
  text   String // enforce 3-240 chars at app layer
  tags   String? // JSON array of tags (max 5), optional for v1

  // Moderation
  status     ReviewStatus      @default(APPROVED)
  heldReason ReviewHeldReason?
  heldAt     DateTime?
  approvedAt DateTime?
  rejectedAt DateTime?

  // Coarse geo at time of posting
  countryCode String? // e.g. "US"
  region      String? // e.g. "UT" (state/region code)

  @@unique([userId]) // One review per user (upsert)
  @@index([status, createdAt])
  @@index([createdAt])
}

// Migration tracking
